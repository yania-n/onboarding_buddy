# ============================================================
# OnboardingBuddy — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# Anthropic Claude (required)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voyage AI (required for embeddings — free tier available)
# Get from: https://dash.voyageai.com
VOYAGE_API_KEY=your_voyage_api_key_here

# Hugging Face (required for deployment)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
HF_SPACE_NAME=your-space-name    # e.g. YourUsername/OnboardingBuddy

# Optional integrations (leave blank to use simulated mode)
SLACK_BOT_TOKEN=
GOOGLE_CALENDAR_TOKEN=
LMS_API_KEY=
IT_PROVISIONING_API_KEY=
